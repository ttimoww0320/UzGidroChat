# Пример конфигурации. Скопируй в .env и заполни реальными значениями.
# Файл .env НИКОГДА не коммитится в git.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=uzgidrochat
POSTGRES_HOST=db

# JWT — сгенерируй командой: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_SECRETS_MODULE

# Срок жизни токена в минутах (по умолчанию 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Разрешённые источники для CORS (через запятую)
CORS_ORIGINS=http://localhost,http://YOUR_SERVER_IP

# Параметры пула соединений с БД
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
